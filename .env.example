# Kopiraj u .env i popuni pravim vrijednostima
# .env se nikad ne commitira u git

NODE_ENV=development

# PostgreSQL connection string (Railway ili lokalni Postgres)
DATABASE_URL=postgresql://user:password@host:port/dbname

# OpenAI API ključ (za FAQ chatbot)
OPENAI_API_KEY=sk-...

# Resend API ključ (za slanje mailova)
RESEND_API_KEY=re_...

# Email adresa s koje se šalju mailovi pacijentima
EMAIL_FROM=onboarding@resend.dev

# Fallback email za obavijesti klinici (ako klinika nema clinicEmail u JSON konfig)
CLINIC_EMAIL=admin@example.com
